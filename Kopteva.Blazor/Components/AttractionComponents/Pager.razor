@implements IDisposable
@rendermode InteractiveServer
@using Kopteva.Blazor.Services
@using Tourist.Domain.Entities

@if (ProductService != null && ProductService.TotalPages > 1)
{
    <div class="btn-group mt-3" role="group" aria-label="Pager">
        <!-- Кнопка Previous -->
        <button type="button" 
                class="btn btn-outline-primary @(previousEnabled ? "" : "disabled")"
                @onclick="@(e => OnPageSelected(ProductService.CurrentPage - 1))">
            <span aria-hidden="true">&laquo;</span>
        </button>

        @for (int i = 1; i <= ProductService.TotalPages; i++)
        {
            var temp = i;
            <button type="button" 
                    class="btn btn-outline-primary @(IsActive(temp) ? "active" : "")"
                    @onclick="@(e => OnPageSelected(temp))">
                @temp
            </button>
        }

        <!-- Кнопка Next -->
        <button type="button" 
                class="btn btn-outline-primary @(nextEnabled ? "" : "disabled")"
                @onclick="@(e => OnPageSelected(ProductService.CurrentPage + 1))">
            <span aria-hidden="true">&raquo;</span>
        </button>
    </div>
}

@code {
    [CascadingParameter]
    public IAttractionService<Tourist.Domain.Entities.Attraction>? ProductService { get; set; }

    protected override void OnInitialized()
    {
        if (ProductService != null)
        {
            ProductService.ListChanged += StateHasChanged;
        }
    }

    // Кнопка Previous доступна?
    bool previousEnabled => ProductService != null && ProductService.CurrentPage != 1;

    // Кнопка Next доступна?
    bool nextEnabled => ProductService != null && ProductService.CurrentPage != ProductService.TotalPages;

    // Это текущая страница?
    bool IsActive(int pageNo) => ProductService != null && pageNo == ProductService.CurrentPage;

    // Обработчик клика по кнопке страницы
    async void OnPageSelected(int pageNo)
    {
        if (ProductService != null)
        {
            await ProductService.GetProducts(pageNo);
        }
    }

    public void Dispose()
    {
        if (ProductService != null)
        {
            ProductService.ListChanged -= StateHasChanged;
        }
    }
}