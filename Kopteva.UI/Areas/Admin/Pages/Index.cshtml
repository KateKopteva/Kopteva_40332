@page
@model Kopteva.UI.Areas.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Администрирование";
}

<h1 class="m-3">Администрирование достопримечательностей</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger m-3">@TempData["Error"]</div>
}

<p class="m-3">
    <a asp-page="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Создать
    </a>
</p>

<div class="container">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Фото</th>
                <th>@Html.DisplayNameFor(model => model.Attractions[0].Name)</th>
                <th>@Html.DisplayNameFor(model => model.Attractions[0].Description)</th>
                <th>@Html.DisplayNameFor(model => model.Attractions[0].TicketPrice)</th>
                <th>Маршрут</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Attractions)
            {
                <tr>
                    <td>
                        @if (item.Image != null)
                        {
                            <img src="@Url.Content("~/" + item.Image)" width="80" alt="@item.Name" />
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Description)</td>
                    <td>
                        @(item.TicketPrice == 0
                            ? "Бесплатно"
                            : $"{item.TicketPrice:N2} руб.")
                    </td>
                    <td>@(item.TourRoute?.Name ?? "Не указан")</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                            <i class="fa-solid fa-info"></i>
                        </a>
                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            <i class="fa-regular fa-trash-can"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>